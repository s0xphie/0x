(* ================================================================ *)
(* §1  SANDPILE FOUNDATIONS                                          *)
(* Abelian sandpile on regular grid, degree-4, boundary sinks       *)
(* Reference: Numberphile/Wolfram Community implementation           *)
(* ================================================================ *)

(* Grid construction *)
n = 32;  (* grid dimension *)
maxHeight = 3;  (* max grains before toppling *)
grid = GridGraph[{n, n}];

(* Sandpile stabilization (Wolfram Language native) *)
stabilize[state_List] := Module[{s = state, tmp},
  While[Max[s] > maxHeight,
    s = ArrayPad[s, 1, 0];
    tmp = Quotient[s, 4];
    s -= 4 tmp;
    s += RotateLeft[tmp, {0, 1}] + RotateLeft[tmp, {1, 0}]
       + RotateLeft[tmp, {0, -1}] + RotateLeft[tmp, {-1, 0}];
    s = ArrayPad[s, -1];
  ];
  s
];

(* Visualize a sandpile state *)
sandpileColors = {0 -> Black, 1 -> RGBColor[0, 0.5, 1],
  2 -> RGBColor[1, 0.8, 0], 3 -> RGBColor[1, 0, 0]};
showSandpile[state_] := ArrayPlot[state /. sandpileColors,
  Frame -> False, ImageSize -> 300];

(* ResourceFunction bridge *)
sandpileTopple[g_, config_] := ResourceFunction["SandpileTopple"][g, config];

