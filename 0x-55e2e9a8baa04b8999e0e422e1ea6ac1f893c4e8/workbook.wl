(* ================================================================ *)
(* §3  12-GLYPH INTERVAL DECODER (SPEC §4)                         *)
(* 4 bands × 3 elements, nearest-anchor decoding                   *)
(* ================================================================ *)


(* 12-Glyph Interval Structure (SPEC §4) *)
(* 4 bands × 3 elements, nearest-anchor decoding *)
glyphAnchors = {64, 78, 92, 96, 113, 132, 133, 151, 166, 169, 185, 201};
glyphSymbols = {"@", "N", "\\", "`", "q", "„", "…", "—", "¦", "©", "¹", "É"};
glyphMap = Association[{64 -> "@", 78 -> "N", 92 -> "\\", 96 -> "`", 113 -> "q", 132 -> "„", 133 -> "…", 151 -> "—", 166 -> "¦", 169 -> "©", 185 -> "¹", 201 -> "É"}];

(* Decode a pixel value to its nearest glyph *)
decodeGlyph[v_Integer] := glyphSymbols[[
  First@Ordering[Abs[glyphAnchors - v], 1]
]];


(* Decode an entire surface to glyph matrix *)
decodeSurface[mat_] := Map[decodeGlyph, mat, {2}];

(* Band assignment *)
glyphBands = {0, 0, 0, 1, 1, 1, 2, 2, 2, 3, 3, 3};
bandOfGlyph[idx_] := glyphBands[[idx]];


(* ================================================================ *)
(* §4  BOUNDARY POTENTIAL (SPEC §5)                                *)
(* ϕ_z(u,v) = h_z(u) - h_z(v)                                     *)
(* Only non-zero potentials define the influence graph              *)
(* ================================================================ *)

(* 23496 boundary edges, max potential = 3 *)

boundaryPotential[mat_] := Module[{h = mat, edges = {}},
  Do[
    If[h[[r, c]] != h[[r, c + 1]],
      AppendTo[edges, {r, c} -> {r, c + 1}]];
    If[h[[r, c]] != h[[r + 1, c]],
      AppendTo[edges, {r, c} -> {r + 1, c}]];
  , {r, Length[h] - 1}, {c, Length[h[[1]]] - 1}];
  edges
];

(* Influence graph from boundary *)
influenceGraph[mat_] := Graph[
  DirectedEdge @@@ boundaryPotential[mat],
  GraphLayout -> "SpringElectricalEmbedding"
];


